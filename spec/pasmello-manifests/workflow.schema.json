{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://market.pasmello.dev/spec/pasmello-manifests/workflow.schema.json",
  "title": "Pasmello WorkflowManifest (vendored)",
  "description": "Mirror of pasmello/packages/shared/src/workflow.ts. Pin and re-sync per Pasmello release.",
  "type": "object",
  "required": ["id", "name", "version", "description", "triggers", "nodes", "edges"],
  "additionalProperties": true,
  "$defs": {
    "trigger": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": { "type": { "const": "manual" } }
        },
        {
          "type": "object",
          "required": ["type", "event"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "ui-event" },
            "event": { "type": "string" },
            "filter": {
              "type": "object",
              "additionalProperties": {
                "type": ["string", "number", "boolean", "null"]
              }
            }
          }
        }
      ]
    },
    "node": {
      "type": "object",
      "required": ["id", "type", "config"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "type": {
          "enum": [
            "tool-action",
            "http-request",
            "code-block",
            "conditional",
            "delay",
            "transform"
          ]
        },
        "config": { "type": "object" },
        "retry": {
          "type": "object",
          "required": ["max", "delayMs"],
          "additionalProperties": false,
          "properties": {
            "max": { "type": "integer", "minimum": 0 },
            "delayMs": { "type": "integer", "minimum": 0 }
          }
        },
        "onError": {
          "oneOf": [
            { "enum": ["fail", "continue"] },
            {
              "type": "object",
              "required": ["goto"],
              "additionalProperties": false,
              "properties": { "goto": { "type": "string" } }
            }
          ]
        },
        "joinMode": { "enum": ["all", "any"] },
        "position": {
          "type": "object",
          "required": ["x", "y"],
          "additionalProperties": false,
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        }
      }
    },
    "edge": {
      "type": "object",
      "required": ["source", "target"],
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string" },
        "target": { "type": "string" },
        "when": { "enum": ["true", "false"] }
      }
    }
  },
  "properties": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "author": { "type": "string" },
    "triggers": {
      "type": "array",
      "items": { "$ref": "#/$defs/trigger" }
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "requiredTools": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
