{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://market.pasmello.com/spec/pasmello-manifests/theme.schema.json",
  "title": "Pasmello ThemeManifest (vendored)",
  "description": "Mirror of pasmello/packages/shared/src/theme.ts. Pin and re-sync per Pasmello release.",
  "type": "object",
  "required": ["id", "name", "version", "description", "builtIn"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "author": { "type": "string" },
    "builtIn": {
      "const": false,
      "description": "Themes distributed via mello are never builtIn — that flag is reserved for themes shipped inside the Pasmello web app."
    },
    "settings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "type", "label", "default"],
        "additionalProperties": false,
        "properties": {
          "key": { "type": "string" },
          "type": { "enum": ["color", "select", "toggle", "range", "text"] },
          "label": { "type": "string" },
          "description": { "type": "string" },
          "default": {},
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["value", "label"],
              "additionalProperties": false,
              "properties": {
                "value": { "type": "string" },
                "label": { "type": "string" }
              }
            }
          },
          "min": { "type": "number" },
          "max": { "type": "number" }
        }
      }
    },
    "tokens": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "darkTokens": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
