{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://market.pasmello.dev/spec/pasmello-manifests/tool.schema.json",
  "title": "Pasmello ToolManifest (vendored)",
  "description": "Mirror of pasmello/packages/shared/src/tool.ts. Pin and re-sync per Pasmello release.",
  "type": "object",
  "required": ["id", "name", "version", "description", "entry", "permissions", "actions"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$",
      "description": "Pasmello's internal tool id. Must be a valid OPFS path segment."
    },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "entry": {
      "type": "string",
      "description": "Path to the single-file HTML entry point inside the zip (e.g. 'dist/index.html')."
    },
    "permissions": {
      "type": "object",
      "required": ["network", "storage", "clipboard", "notifications", "camera", "geolocation"],
      "additionalProperties": false,
      "properties": {
        "network": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Allowlist of origins the tool may fetch from. Host validates every request."
        },
        "storage": { "enum": ["none", "read", "read-write"] },
        "clipboard": { "enum": ["none", "read", "read-write"] },
        "notifications": { "type": "boolean" },
        "camera": { "type": "boolean" },
        "geolocation": { "type": "boolean" }
      }
    },
    "actions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["description", "inputs", "outputs"],
        "additionalProperties": false,
        "properties": {
          "description": { "type": "string" },
          "inputs": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "outputs": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    }
  }
}
