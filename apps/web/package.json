{
  "name": "@mello/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "mello marketplace web UI (market.pasmello.dev)",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "deploy": "wrangler pages deploy build --project-name=market-pasmello-dev",
    "clean": "rm -rf build .svelte-kit"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.5",
    "@sveltejs/kit": "^2.6.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vitest": "^2.1.1",
    "wrangler": "^3.80.0"
  }
}
