# Registry API base URL. In prod: https://registry.pasmello.com
# In dev: http://localhost:8787
# Legacy name PUBLIC_API_BASE still accepted as a fallback.
PUBLIC_API_URL=http://localhost:8787

# Pasmello install target. The "Open in Pasmello" button composes:
#   {PUBLIC_PASMELLO_ORIGIN}/?install=<cdn-url>
# In prod: https://pasmello.com
# In dev: http://localhost:5173 (Pasmello's default vite port; mello web
# itself runs at 5180 to avoid the conflict)
PUBLIC_PASMELLO_ORIGIN=https://pasmello.com
