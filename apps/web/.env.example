# Registry API base URL. In prod: https://market.pasmello.dev
# In dev: http://localhost:8787
PUBLIC_API_BASE=http://localhost:8787

# Pasmello install target. The "Open in Pasmello" button composes:
#   {PUBLIC_PASMELLO_ORIGIN}/?install=<cdn-url>
# In prod: https://pasmello.dev
# In dev: http://localhost:5174 (or wherever Pasmello's dev server runs)
PUBLIC_PASMELLO_ORIGIN=https://pasmello.dev
