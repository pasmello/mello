# API listen address (Fly maps this to 0.0.0.0:8080 internally)
PORT=8787
HOST=0.0.0.0

# Postgres (Neon in prod; local postgres in dev)
DATABASE_URL=postgres://mello:mello@localhost:5432/mello

# R2 / S3-compatible storage
# In prod: use Cloudflare R2 S3 API credentials
# In dev: points at local MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=mello-packages
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Public CDN base URL that fronts the bucket
CDN_BASE_URL=http://localhost:9000/mello-packages

# GitHub OAuth (device flow)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Pasmello SaaS endpoint used for paid-plugin verify-access (future).
# MVP leaves this unset; verify-access returns {tier: "free"} for all packages.
PASMELLO_SAAS_VERIFY_URL=

# Admin bootstrap: comma-separated GitHub logins that get admin role at first login
ADMIN_LOGINS=
